{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "forgeStack": {
    "kind": "ui-app",
    "runtime": "nextjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:vps": "next build",
    "start:vps": "next start",
    "build:cloudflare": "opennextjs-cloudflare build",
    "preview:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:vercel": "vercel --prod",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tenora/client": "workspace:*",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.8.3",
    "vercel": "^54.14.5",
    "wrangler": "^4.103.0"
  }
}
