# Copy this file to `.env` at the repository root:
#   cp .env.example .env

# ── Server (app/api) ──────────────────────────────────────────────────────────
TENORA_API_PORT=3001
# ── Web (app/web) ─────────────────────────────────────────────────────────────
TENORA_WEB_PORT=3000

# Browser API base URL (`/api` = same origin; full URL when API is on another host)
TENORA_API_URL=/api

# ── Cloudflare Worker (optional) ──────────────────────────────────────────────
# For `pnpm --filter api dev:cloudflare`, copy secrets to app/api/.dev.vars
# DATABASE_URL=postgres://...

# Optional. Required when using database-backed features.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tenora
