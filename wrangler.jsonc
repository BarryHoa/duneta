{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "duneta",
  "main": "worker.ts",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "NODE_ENV": "production"
  }
  // Dev + build (Vite resolves virtual:react-router/server-build).
  // Deploy: pnpm deploy → app/build/server/wrangler.json after build.
  //
  // Secrets: .dev.vars (local) or wrangler secret put (production)
}
