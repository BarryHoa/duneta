{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "duneta",
  "main": "worker.ts",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "NODE_ENV": "production"
  },
  "assets": {
    "directory": "app/build/client",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "<your-hyperdrive-config-id>"
    }
  ]
}
