{
  "name": "tenora",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev": "node scripts/dev.mjs",
    "dev:cloudflare": "node scripts/dev.mjs cloudflare",
    "create": "pnpm --filter create-tenora start",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "format": "prettier --write .",
    "version:check": "node scripts/version.mjs check",
    "version:sync": "node scripts/version.mjs sync",
    "version:bump": "node scripts/version.mjs bump"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
