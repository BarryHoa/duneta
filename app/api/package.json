{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "forgeStack": {
    "kind": "backend-app",
    "runtime": "hono"
  },
  "scripts": {
    "dev": "tenora-api dev",
    "dev:cloudflare": "tenora-api dev:cloudflare",
    "build": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "start": "tenora-api start",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "deploy:cloudflare": "tenora-api deploy:cloudflare"
  },
  "dependencies": {
    "@tenora/server": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250617.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.0"
  }
}
