{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tenora-api",
  "main": "server.ts",
  "compatibility_date": "2025-06-17",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "RUNTIME": "worker"
  },
  // Optional: Hyperdrive → any Postgres (Neon, Supabase, RDS…). No tenora.config changes.
  // npx wrangler hyperdrive create tenora-db --connection-string="postgresql://..."
  // "hyperdrive": [{ "binding": "HYPERDRIVE", "id": "<hyperdrive-config-id>" }]
  //
  // Secrets (wrangler secret put):
  //   AUTH_SECRET, AUTH_BASE_URL
  //   CACHE_URL, CACHE_TOKEN
  //   DATABASE_URL  (fallback if Hyperdrive not used)
}
