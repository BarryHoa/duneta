# Server — used by tenora.config.ts (Node + Worker via wrangler secrets/vars)

# RUNTIME=node | worker
PORT=3001
NODE_ENV=development

# DATABASE_URL=postgresql://user:pass@localhost:5432/tenora
# AUTH_SECRET=your-32-char-minimum-secret
# AUTH_BASE_URL=http://localhost:3001

# Cache — driver: memory | redis | memcached
# CACHE_DRIVER=redis
# CACHE_URL=https://your-cache-http-endpoint   # or redis://host:6379 (TCP, Node)
# CACHE_TOKEN=optional-http-bearer-token

# Rate limit — set RATE_LIMIT_ENABLED=false to disable
# RATE_LIMIT_ENABLED=true

# Optional — web dev tooling only
# CONFIG_WEB_PORT=3000
# CONFIG_API_PROXY_TARGET=http://localhost:3001
