# Values for duneta.config.ts — runtime is chosen by entry file, not env.

PORT=3001
NODE_ENV=development

# Postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/duneta

# Auth (optional)
# AUTH_SECRET=your-32-char-minimum-secret
# AUTH_BASE_URL=http://localhost:3001

# Cache — enable in duneta.config.ts with redisCache({ url, token })
# CACHE_URL=https://your-redis-http-endpoint
# CACHE_TOKEN=your-bearer-token

# Cloud (server.ts): wrangler secrets + optional Hyperdrive in wrangler.jsonc
# AUTH_BASE_URL=http://localhost:8787
