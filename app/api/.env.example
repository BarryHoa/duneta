# Minimal — values for tenora.config.ts (via envFirst)

RUNTIME=node
PORT=3001
NODE_ENV=development

# Postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/tenora

# Auth (optional)
# AUTH_SECRET=your-32-char-minimum-secret
# AUTH_BASE_URL=http://localhost:3001

# Cache — enable in tenora.config.ts with redisCache({ url, token })
# CACHE_URL=https://your-redis-http-endpoint
# CACHE_TOKEN=your-bearer-token

# Worker: RUNTIME=worker + wrangler secrets / Hyperdrive in wrangler.jsonc
