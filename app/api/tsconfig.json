{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types", "node"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@tenora/server/configs": ["../../packages/server/configs/index.ts"],
      "@tenora/server/*": ["../../packages/server/*"]
    }
  },
  "include": [
    "server.ts",
    "server.node.ts",
    "tenora.config.ts",
