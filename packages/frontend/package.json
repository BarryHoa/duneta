{
  "name": "@tenora/client",
  "private": false,
  "version": "0.1.0",
  "description": "Browser-safe utilities for Tenora applications.",
  "license": "MIT",
  "type": "module",
  "files": ["dist"],
  "forgeStack": { "kind": "frontend", "runtime": "browser-or-nextjs" },
  "exports": {
    "./config": { "types": "./dist/config/index.d.ts", "import": "./dist/config/index.js" },
    "./validators": { "types": "./dist/validators/index.d.ts", "import": "./dist/validators/index.js" },
    "./helpers": { "types": "./dist/helpers/index.d.ts", "import": "./dist/helpers/index.js" },
    "./themes": { "types": "./dist/themes/index.d.ts", "import": "./dist/themes/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "import": "./dist/components/index.js" },
    "./layouts": { "types": "./dist/layouts/index.d.ts", "import": "./dist/layouts/index.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": { "access": "public" },
  "dependencies": { "zod": "^3.24.0" },
  "devDependencies": { "typescript": "^5.8.3" }
}
