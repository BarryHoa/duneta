{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": "."
  },
  "include": [
    "assembly",
    "auth",
    "permissions",
    "cache",
    "cached",
    "configs",
    "container",
    "database",
    "http",
    "middlewares",
    "repositories",
    "routers",
    "runtime"
  ],
  "exclude": ["dist", "node_modules"]
}
