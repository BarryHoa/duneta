{
  "name": "@duneta/server",
  "private": false,
  "version": "0.1.0",
  "description": "Server utilities for Duneta applications.",
  "license": "MIT",
  "type": "module",
  "files": ["dist", "scripts"],
  "forgeStack": { "kind": "backend", "runtime": "cloudflare-worker" },
  "exports": {
    "./package.json": "./package.json",
    "./configs": {
      "types": "./dist/configs/index.d.ts",
      "import": "./dist/configs/index.js"
    },
    "./scripts/sync-api": "./scripts/sync-api.mjs",
    "./middlewares": { "types": "./dist/middlewares/index.d.ts", "import": "./dist/middlewares/index.js" },
    "./repositories": { "types": "./dist/repositories/index.d.ts", "import": "./dist/repositories/index.js" },
    "./assembly": { "types": "./dist/assembly/index.d.ts", "import": "./dist/assembly/index.js" },
    "./routers": { "types": "./dist/routers/index.d.ts", "import": "./dist/routers/index.js" },
    "./auth": { "types": "./dist/auth/index.d.ts", "import": "./dist/auth/index.js" },
    "./permissions": { "types": "./dist/permissions/index.d.ts", "import": "./dist/permissions/index.js" },
    "./container": { "types": "./dist/container/index.d.ts", "import": "./dist/container/index.js" },
    "./database": { "types": "./dist/database/index.d.ts", "import": "./dist/database/index.js" },
    "./http": { "types": "./dist/http/index.d.ts", "import": "./dist/http/index.js" },
    "./cache": { "types": "./dist/cache/index.d.ts", "import": "./dist/cache/index.js" },
    "./cached": { "types": "./dist/cached/index.d.ts", "import": "./dist/cached/index.js" },
    "./logging": { "types": "./dist/logging/index.d.ts", "import": "./dist/logging/index.js" },
    "./runtime/worker": {
      "types": "./dist/runtime/worker/index.d.ts",
      "import": "./dist/runtime/worker/index.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "pg": "^8.16.0",
    "zod": "^3.24.0"
  },
  "devDependencies": { "@types/pg": "^8.15.0", "typescript": "^5.8.3" }
}
