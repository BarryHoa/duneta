{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vite/client", "@react-router/dev/routes"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"],
      "@tenora/client": ["./node_modules/@tenora/client"],
      "@tenora/client/*": ["./node_modules/@tenora/client/*"]
    },
    "rootDirs": [".", "./.react-router/types"],
    "noEmit": true
  },
  "include": ["**/*", ".router-runtime/**/*", ".react-router/types/**/*"],
  "exclude": ["node_modules", "build"]
}
