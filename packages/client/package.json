{
  "name": "@tenora/client",
  "private": false,
  "version": "0.1.0",
  "description": "Browser-safe utilities and React Router web kit for Tenora applications.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "configs",
    "routers",
    "config",
    "providers",
    "themes",
    "scripts"
  ],
  "bin": {
    "tenora-web": "./scripts/tenora-web.mjs"
  },
  "forgeStack": {
    "kind": "frontend",
    "runtime": "browser-or-react-router"
  },
  "exports": {
    "./configs": {
      "types": "./configs/index.ts",
      "import": "./configs/index.ts",
      "default": "./configs/index.ts"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./config/vite": "./config/vite.ts",
    "./config/react-router": "./config/react-router.ts",
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.js"
    },
    "./hooks/link": {
      "types": "./dist/hooks/link/index.d.ts",
      "import": "./dist/hooks/link/index.js"
    },
    "./hooks/use-api": {
      "types": "./dist/hooks/use-api.d.ts",
      "import": "./dist/hooks/use-api.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/IbaseInput": {
      "types": "./dist/components/IbaseInput/index.d.ts",
      "import": "./dist/components/IbaseInput/index.js"
    },
    "./components/IbaseSelect": {
      "types": "./dist/components/IbaseSelect/index.d.ts",
      "import": "./dist/components/IbaseSelect/index.js"
    },
    "./components/IbaseForm": {
      "types": "./dist/components/IbaseForm/index.d.ts",
      "import": "./dist/components/IbaseForm/index.js"
    },
    "./components/IbaseUpload": {
      "types": "./dist/components/IbaseUpload/index.d.ts",
      "import": "./dist/components/IbaseUpload/index.js"
    },
    "./components/IbaseTable": {
      "types": "./dist/components/IbaseTable/index.d.ts",
      "import": "./dist/components/IbaseTable/index.js"
    },
    "./components/IbaseError": {
      "types": "./dist/components/IbaseError/index.d.ts",
      "import": "./dist/components/IbaseError/index.js"
    },
    "./components/IbaseLayout": {
      "types": "./dist/components/IbaseLayout/index.d.ts",
      "import": "./dist/components/IbaseLayout/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./themes/globals.css": "./themes/globals.css"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@react-router/dev": "^8.0.1",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "@tanstack/react-virtual": "^3.14.3",
    "dayjs": "^1.11.21",
    "lodash": "^4.18.1",
    "isbot": "^5.1.32",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "tailwind-variants": "^3.2.2",
    "vite": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  }
}
