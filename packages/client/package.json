{
  "name": "@duneta/client",
  "private": false,
  "version": "0.1.0",
  "description": "Browser-safe utilities and React Router web kit for Duneta applications.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "configs",
    "routers",
    "providers",
    "themes",
    "scripts"
  ],
  "bin": {
    "duneta-web": "./scripts/duneta-web.mjs"
  },
  "forgeStack": {
    "kind": "frontend",
    "runtime": "browser-or-react-router"
  },
  "exports": {
    "./configs": {
      "types": "./configs/index.ts",
      "import": "./configs/index.ts",
      "default": "./configs/index.ts"
    },
    "./configs/vite": "./configs/vite.ts",
    "./configs/react-router": "./configs/react-router.ts",
    "./configs/load": "./configs/load.ts",
    "./configs/client": "./configs/client.ts",
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.js"
    },
    "./hooks/link": {
      "types": "./dist/hooks/link/index.d.ts",
      "import": "./dist/hooks/link/index.js"
    },
    "./hooks/use-api": {
      "types": "./dist/hooks/use-api.d.ts",
      "import": "./dist/hooks/use-api.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/DunetaAlertDialog": {
      "types": "./dist/components/DunetaAlertDialog/index.d.ts",
      "import": "./dist/components/DunetaAlertDialog/index.js"
    },
    "./components/DunetaButton": {
      "types": "./dist/components/DunetaButton/index.d.ts",
      "import": "./dist/components/DunetaButton/index.js"
    },
    "./components/DunetaLink": {
      "types": "./dist/components/DunetaLink/index.d.ts",
      "import": "./dist/components/DunetaLink/index.js"
    },
    "./components/DunetaLoadError": {
      "types": "./dist/components/DunetaLoadError/index.d.ts",
      "import": "./dist/components/DunetaLoadError/index.js"
    },
    "./components/DunetaSimpleTable": {
      "types": "./dist/components/DunetaSimpleTable/index.d.ts",
      "import": "./dist/components/DunetaSimpleTable/index.js"
    },
    "./components/DunetaInput": {
      "types": "./dist/components/DunetaInput/index.d.ts",
      "import": "./dist/components/DunetaInput/index.js"
    },
    "./components/DunetaSelect": {
      "types": "./dist/components/DunetaSelect/index.d.ts",
      "import": "./dist/components/DunetaSelect/index.js"
    },
    "./components/DunetaForm": {
      "types": "./dist/components/DunetaForm/index.d.ts",
      "import": "./dist/components/DunetaForm/index.js"
    },
    "./components/DunetaUpload": {
      "types": "./dist/components/DunetaUpload/index.d.ts",
      "import": "./dist/components/DunetaUpload/index.js"
    },
    "./components/DunetaTable": {
      "types": "./dist/components/DunetaTable/index.d.ts",
      "import": "./dist/components/DunetaTable/index.js"
    },
    "./components/DunetaDataTable": {
      "types": "./dist/components/DunetaDataTable/index.d.ts",
      "import": "./dist/components/DunetaDataTable/index.js"
    },
    "./components/DunetaLayout": {
      "types": "./dist/components/DunetaLayout/index.d.ts",
      "import": "./dist/components/DunetaLayout/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./themes/globals.css": "./themes/globals.css"
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@react-router/dev": "^8.0.1",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "dayjs": "^1.11.21",
    "isbot": "^5.1.32",
    "lodash": "^4.18.1",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "tailwind-variants": "^3.2.2",
    "vite": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  }
}
