{
  "name": "@tenora/client",
  "private": false,
  "version": "0.1.0",
  "description": "Browser-safe utilities and React Router web kit for Tenora applications.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "configs",
    "routers",
    "providers",
    "themes",
    "scripts"
  ],
  "bin": {
    "tenora-web": "./scripts/tenora-web.mjs"
  },
  "forgeStack": {
    "kind": "frontend",
    "runtime": "browser-or-react-router"
  },
  "exports": {
    "./configs": {
      "types": "./configs/index.ts",
      "import": "./configs/index.ts",
      "default": "./configs/index.ts"
    },
    "./configs/vite": "./configs/vite.ts",
    "./configs/react-router": "./configs/react-router.ts",
    "./configs/client": "./configs/client.ts",
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.js"
    },
    "./hooks/link": {
      "types": "./dist/hooks/link/index.d.ts",
      "import": "./dist/hooks/link/index.js"
    },
    "./hooks/use-api": {
      "types": "./dist/hooks/use-api.d.ts",
      "import": "./dist/hooks/use-api.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/TenoraAlertDialog": {
      "types": "./dist/components/TenoraAlertDialog/index.d.ts",
      "import": "./dist/components/TenoraAlertDialog/index.js"
    },
    "./components/TenoraButton": {
      "types": "./dist/components/TenoraButton/index.d.ts",
      "import": "./dist/components/TenoraButton/index.js"
    },
    "./components/TenoraLink": {
      "types": "./dist/components/TenoraLink/index.d.ts",
      "import": "./dist/components/TenoraLink/index.js"
    },
    "./components/TenoraLoadError": {
      "types": "./dist/components/TenoraLoadError/index.d.ts",
      "import": "./dist/components/TenoraLoadError/index.js"
    },
    "./components/TenoraSimpleTable": {
      "types": "./dist/components/TenoraSimpleTable/index.d.ts",
      "import": "./dist/components/TenoraSimpleTable/index.js"
    },
    "./components/TenoraInput": {
      "types": "./dist/components/TenoraInput/index.d.ts",
      "import": "./dist/components/TenoraInput/index.js"
    },
    "./components/TenoraSelect": {
      "types": "./dist/components/TenoraSelect/index.d.ts",
      "import": "./dist/components/TenoraSelect/index.js"
    },
    "./components/TenoraForm": {
      "types": "./dist/components/TenoraForm/index.d.ts",
      "import": "./dist/components/TenoraForm/index.js"
    },
    "./components/TenoraUpload": {
      "types": "./dist/components/TenoraUpload/index.d.ts",
      "import": "./dist/components/TenoraUpload/index.js"
    },
    "./components/TenoraTable": {
      "types": "./dist/components/TenoraTable/index.d.ts",
      "import": "./dist/components/TenoraTable/index.js"
    },
    "./components/TenoraDataTable": {
      "types": "./dist/components/TenoraDataTable/index.d.ts",
      "import": "./dist/components/TenoraDataTable/index.js"
    },
    "./components/TenoraLayout": {
      "types": "./dist/components/TenoraLayout/index.d.ts",
      "import": "./dist/components/TenoraLayout/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./themes/globals.css": "./themes/globals.css"
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@react-router/dev": "^8.0.1",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "dayjs": "^1.11.21",
    "lodash": "^4.18.1",
    "isbot": "^5.1.32",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "tailwind-variants": "^3.2.2",
    "vite": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  }
}
