{
  "name": "@duneta/client",
  "private": false,
  "version": "0.1.0",
  "description": "Browser-safe utilities and React Router web kit for Duneta applications.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "configs",
    "core",
    "runtime",
    "router",
    "ui",
    "starter",
    "themes",
    "scripts"
  ],
  "forgeStack": {
    "kind": "frontend",
    "runtime": "browser-or-react-router"
  },
  "exports": {
    "./package.json": "./package.json",
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./ui/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./configs": {
      "types": "./dist/configs/index.d.ts",
      "import": "./dist/configs/index.js"
    },
    "./configs/vite": {
      "types": "./dist/configs/vite.d.ts",
      "import": "./dist/configs/vite.js"
    },
    "./configs/react-router": {
      "types": "./dist/configs/react-router.d.ts",
      "import": "./dist/configs/react-router.js"
    },
    "./configs/load": {
      "types": "./dist/configs/load.d.ts",
      "import": "./dist/configs/load.js"
    },
    "./configs/bootstrap": {
      "types": "./dist/configs/bootstrap.d.ts",
      "import": "./dist/configs/bootstrap.js"
    },
    "./configs/duneta": {
      "types": "./dist/configs/duneta.d.ts",
      "import": "./dist/configs/duneta.js"
    },
    "./scripts/sync-routers": "./scripts/sync-routers.mjs",
    "./scripts/load-config": "./scripts/load-config.mjs",
    "./starter/layouts": {
      "types": "./dist/starter/layouts/index.d.ts",
      "import": "./dist/starter/layouts/index.js"
    },
    "./starter/layouts/duneta-home.css": "./starter/layouts/duneta-home.css",
    "./themes/globals.css": "./themes/globals.css"
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@react-router/dev": "^8.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "dayjs": "^1.11.21",
    "isbot": "^5.1.32",
    "lodash": "^4.18.1",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "tailwindcss": "^4.3.1",
    "tailwind-variants": "^3.2.2",
    "vite": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  }
}
