{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@duneta/client": ["."],
      "@duneta/client/*": ["./*"]
    },
    "noEmit": true
  },
  "include": [
    "configs",
    "core",
    "validators",
    "runtime",
    "router",
    "ui",
    "components",
    "starter"
  ]
}
