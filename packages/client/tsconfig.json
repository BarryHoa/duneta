{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@duneta/client": ["."],
      "@duneta/client/*": ["./*"]
    },
    "noEmit": true
  },
  "include": [
    "configs",
    "env.d.ts",
    "validators",
    "helpers",
    "hooks",
    "components",
    "layouts",
    "providers",
    "routers"
  ]
}
