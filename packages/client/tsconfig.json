{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@duneta/client": ["."],
      "@duneta/client/*": ["./*"]
    },
    "noEmit": true
  },
  "include": [
    "configs",
    "core",
    "validators",
    "http",
    "query",
    "form",
    "feedback",
    "i18n",
    "helpers",
    "providers",
    "image",
    "script",
    "router",
    "ui",
    "components",
    "starter"
  ]
}
