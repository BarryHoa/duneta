{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types", "node", "vite/client"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "rootDirs": [".", "./app/.react-router/types"],
    "paths": {
      "@duneta/client": ["packages/client"],
      "@duneta/client/*": ["packages/client/*"],
      "@duneta/server/*": ["packages/server/*"],
      "~/*": ["app/*"]
    }
  },
  "include": [
    "worker.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "duneta.client.config.ts",
    "duneta.server.config.ts",
    "app/.router-runtime/**/*",
    "app/.react-router/types/+server-build.d.ts"
  ]
}
